            <xsd:restriction base="xsd:string">
             <xsd:maxLength value="17"/>
            </xsd:restriction>
           </xsd:simpleType>
          </xsd:element>
          <xsd:element name="ZOLLB" minOccurs="0">
           <xsd:annotation>
            <xsd:documentation>Posto di dogana di destin.</xsd:documentation>
           </xsd:annotation>
           <xsd:simpleType>
            <xsd:restriction base="xsd:string">
             <xsd:maxLength value="17"/>
            </xsd:restriction>
           </xsd:simpleType>
          </xsd:element>
          <xsd:element name="ZOLL1" minOccurs="0">
           <xsd:annotation>
            <xsd:documentation>Posto dog. 1</xsd:documentation>
           </xsd:annotation>
           <xsd:simpleType>
            <xsd:restriction base="xsd:string">
             <xsd:maxLength value="17"/>
            </xsd:restriction>
           </xsd:simpleType>
          </xsd:element>
          <xsd:element name="ZOLL2" minOccurs="0">
           <xsd:annotation>
            <xsd:documentation>Posto dog. 2</xsd:documentation>
           </xsd:annotation>
           <xsd:simpleType>
            <xsd:restriction base="xsd:string">
             <xsd:maxLength value="17"/>
            </xsd:restriction>
           </xsd:simpleType>
          </xsd:element>
          <xsd:element name="ZOLL3" minOccurs="0">
           <xsd:annotation>
            <xsd:documentation>Posto dog. 3</xsd:documentation>
           </xsd:annotation>
           <xsd:simpleType>
            <xsd:restriction base="xsd:string">
             <xsd:maxLength value="17"/>
            </xsd:restriction>
           </xsd:simpleType>
          </xsd:element>
          <xsd:element name="ZOLL4" minOccurs="0">
           <xsd:annotation>
            <xsd:documentation>Posto dog. 4</xsd:documentation>
           </xsd:annotation>
           <xsd:simpleType>
            <xsd:restriction base="xsd:string">
             <xsd:maxLength value="17"/>
            </xsd:restriction>
           </xsd:simpleType>
          </xsd:element>
          <xsd:element name="ZOLL5" minOccurs="0">
           <xsd:annotation>
            <xsd:documentation>Posto dog. 5</xsd:documentation>
           </xsd:annotation>
           <xsd:simpleType>
            <xsd:restriction base="xsd:string">
             <xsd:maxLength value="17"/>
            </xsd:restriction>
           </xsd:simpleType>
          </xsd:element>
          <xsd:element name="ZOLL6" minOccurs="0">
           <xsd:annotation>
            <xsd:documentation>Posto dog. 6</xsd:documentation>
           </xsd:annotation>
           <xsd:simpleType>
            <xsd:restriction base="xsd:string">
             <xsd:maxLength value="17"/>
            </xsd:restriction>
           </xsd:simpleType>
          </xsd:element>
          <xsd:element name="KZGBE" minOccurs="0">
           <xsd:annotation>
            <xsd:documentation>Chiave dei mezzi di trasporto diretti all&apos; estero</xsd:documentation>
           </xsd:annotation>
           <xsd:simpleType>
            <xsd:restriction base="xsd:string">
             <xsd:maxLength value="30"/>
            </xsd:restriction>
           </xsd:simpleType>
          </xsd:element>
          <xsd:element name="KZABE" minOccurs="0">
           <xsd:annotation>
            <xsd:documentation>Codice mezzo di trasporto alla partenza della merce</xsd:documentation>
           </xsd:annotation>
           <xsd:simpleType>
            <xsd:restriction base="xsd:string">
             <xsd:maxLength value="30"/>
            </xsd:restriction>
           </xsd:simpleType>
          </xsd:element>
          <xsd:element name="STGBE" minOccurs="0">
           <xsd:annotation>
            <xsd:documentation>Stato di provenienza del mezzo di trasporto al confine</xsd:documentation>
           </xsd:annotation>
           <xsd:simpleType>
            <xsd:restriction base="xsd:string">
             <xsd:maxLength value="17"/>
            </xsd:restriction>
           </xsd:simpleType>
          </xsd:element>
          <xsd:element name="STABE" minOccurs="0">
