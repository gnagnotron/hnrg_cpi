${header_CORRELATION_ID} = ${header.SAP_MessageProcessingLogID}
${header.IFLOW_NAME} = ${camelId}
${header.EXCEPTION_MESSAGE} = TBD
${header.MESSAGE}, ${header.MESSAGE2}, ecc</bpmn2:documentation>
