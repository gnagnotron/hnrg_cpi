        <bpmn2:callActivity id="CallActivity_9" name="set message body">
            <bpmn2:extensionElements>
                <ifl:property>
                    <key>bodyType</key>
                    <value>expression</value>
                </ifl:property>
                <ifl:property>
                    <key>propertyTable</key>
                    <value/>
                </ifl:property>
                <ifl:property>
                    <key>headerTable</key>
                    <value/>
                </ifl:property>
                <ifl:property>
                    <key>wrapContent</key>
                    <value>&lt;!DOCTYPE html&gt;
&lt;html lang="it"&gt;
&lt;head&gt;
    &lt;meta charset="UTF-8"&gt;
    &lt;meta name="viewport" content="width=device-width, initial-scale=1.0"&gt;
    &lt;title&gt;Email Notification&lt;/title&gt;
    &lt;style&gt;
        body {
            font-family: Arial, sans-serif;
            color: #000000;
        }
        .container {
            width: 100%;
            max-width: 600px;
            margin: auto;
            border: 1px solid #dddddd;
            padding: 20px;
        }
        .header {
            text-align: right;
        }
        .header img {
            width: 60px;
            height: 60px;
        }
        .content {
            margin-top: 20px;
        }
        .content p {
            font-size: 15px;
        }
        .content b {
            font-size: 15px;
        }
        .content a {
            color: #1E90FF;
            text-decoration: none;
            font-size: 15px;
        }
        .content a:hover {
            text-decoration: underline;
        }
        .table-container {
            margin-top: 30px;
            width: 100%;
        }
        .table-container table {
            width: 100%;
            border-collapse: collapse;
        }
        .table-container td {
            padding: 10px;
            border: 1px solid #dddddd;
        }
        .blue-bg {
            background-color: #00BFFF;
            color: white;
        }
        .light-blue-bg {
            background-color: #1E90FF;
            color: white;
        }
    &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
    &lt;div class="container"&gt;
        &lt;div class="header"&gt;
            &lt;img src="https://th.bing.com/th/id/OIP.5BfaVQJUih4hd8etGT0RdQHaDx?w=314&amp;h=178&amp;c=7&amp;r=0&amp;o=5&amp;dpr=1.5&amp;pid=1.7" alt="img"/&gt;
        &lt;/div&gt;
        &lt;div class="content"&gt;
            &lt;p&gt;${header.MESSAGE}&lt;/p&gt;
            &lt;p&gt;&lt;a href="https://${sysenv.TENANT_NAME}.integrationsuite.${sysenv.IT_TENANT_UX_DOMAIN}/shell/monitoring/Messages/%7B%22identifier%22%3A%22${header.LOG_ID}%22%7D"&gt;Monitor&lt;/a&gt;&lt;/p&gt;
        &lt;/div&gt;
        &lt;div class="table-container"&gt;
            &lt;table&gt;
                &lt;tr&gt;
                    &lt;td class="blue-bg"&gt;&lt;b&gt;CPI Tenant:&lt;/b&gt;&lt;/td&gt;
                    &lt;td&gt;${header.TENANT_NAME}&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;
                    &lt;td class="light-blue-bg"&gt;&lt;b&gt;Date:&lt;/b&gt;&lt;/td&gt;
                    &lt;td&gt;${date:now:yyyy-MM-dd}&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;
                    &lt;td class="blue-bg"&gt;&lt;b&gt;Time:&lt;/b&gt;&lt;/td&gt;
                    &lt;td&gt;${date:now:hh:mm:ss}&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;
                    &lt;td class="light-blue-bg"&gt;&lt;b&gt;Message ID:&lt;/b&gt;&lt;/td&gt;
                    &lt;td&gt;${header.SAP_MessageProcessingLogID}&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;
                    &lt;td class="blue-bg"&gt;&lt;b&gt;Integration Flow Name:&lt;/b&gt;&lt;/td&gt;
                    &lt;td&gt;${header.IFLOW_NAME}&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;
                    &lt;td class="light-blue-bg"&gt;&lt;b&gt;Exception Message:&lt;/b&gt;&lt;/td&gt;
                    &lt;td&gt;${header.EXCEPTION_MESSAGE}&lt;/td&gt;
                &lt;/tr&gt;
            &lt;/table&gt;
        &lt;/div&gt;
    &lt;/div&gt;
&lt;/body&gt;
&lt;/html&gt;</value>
                </ifl:property>
                <ifl:property>
                    <key>componentVersion</key>
                    <value>1.6</value>
                </ifl:property>
                <ifl:property>
                    <key>activityType</key>
                    <value>Enricher</value>
                </ifl:property>
                <ifl:property>
                    <key>cmdVariantUri</key>
                    <value>ctype::FlowstepVariant/cname::Enricher/version::1.6.0</value>
                </ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_3</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_10</bpmn2:outgoing>
        </bpmn2:callActivity>
